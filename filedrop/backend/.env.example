# ══════════════════════════════════════════════
#  FileDrop — Variables de entorno
#  Copiá este archivo a .env y completá los valores
# ══════════════════════════════════════════════

# Puerto del servidor (Render lo asigna solo en producción)
PORT=3001

# URL del frontend para CORS
# Local:      http://localhost:5500
# Producción: https://tu-app.vercel.app
FRONTEND_URL=http://localhost:5500

# ── Google Drive API (Service Account) ────────
# Pegá el contenido JSON completo del Service Account como string
# Ejemplo: {"type":"service_account","project_id":"...","private_key":"..."}
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"REEMPLAZAR","private_key_id":"REEMPLAZAR","private_key":"-----BEGIN PRIVATE KEY-----\nREEMPLAZAR\n-----END PRIVATE KEY-----\n","client_email":"REEMPLAZAR@REEMPLAZAR.iam.gserviceaccount.com","client_id":"REEMPLAZAR","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ID de la carpeta en Google Drive (de la URL: drive.google.com/drive/folders/ESTE_ID)
GOOGLE_DRIVE_FOLDER_ID=REEMPLAZAR

# ── Firebase / Firestore ───────────────────────
# Podés usar el mismo Service Account de Google (si tiene permisos de Firestore)
# o uno distinto. Pegá el JSON completo acá.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"REEMPLAZAR","private_key_id":"REEMPLAZAR","private_key":"-----BEGIN PRIVATE KEY-----\nREEMPLAZAR\n-----END PRIVATE KEY-----\n","client_email":"REEMPLAZAR@REEMPLAZAR.iam.gserviceaccount.com","client_id":"REEMPLAZAR","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ID del proyecto de Firebase (lo encontrás en la Consola de Firebase > Configuración)
FIREBASE_PROJECT_ID=REEMPLAZAR

# ── Límites ─────────────────────────────────────
# Tamaño máximo de archivo en bytes (10 MB = 10485760)
MAX_FILE_SIZE=10485760

# Horas hasta que expiran los archivos
FILE_EXPIRY_HOURS=24

# Máximo de archivos por grupo (por contraseña)
MAX_FILES_PER_GROUP=20

# ── Rate Limiting ──────────────────────────────
# Requests por IP cada 15 minutos (general)
RATE_LIMIT_MAX=30

# Uploads por IP por hora
UPLOAD_RATE_LIMIT_MAX=15
